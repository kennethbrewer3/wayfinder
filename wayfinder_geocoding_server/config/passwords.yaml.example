# Copy to `passwords.yaml` for local development (Dart on host, not Docker).
# Docker deployments use SERVERPOD_PASSWORD_* variables in `.env` instead.
#
# Generate unique values for each secret — do not use these placeholders as-is.

shared:
  mySharedPassword: 'replace-me'

development:
  database: 'replace-me'
  redis: 'replace-me'
  serviceSecret: 'replace-me'
  emailSecretHashPepper: 'replace-me'
  jwtHmacSha512PrivateKey: 'replace-me'
  jwtRefreshTokenHashPepper: 'replace-me'

test:
  database: 'replace-me'
  redis: 'replace-me'
  emailSecretHashPepper: 'replace-me'
  jwtHmacSha512PrivateKey: 'replace-me'
  jwtRefreshTokenHashPepper: 'replace-me'
