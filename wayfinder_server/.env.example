# Copy to `.env` in this directory before starting the server stack.
#
#   docker compose up -d --build
#
# All persistent data (Postgres, Redis, PMTiles) is stored under WAYFINDER_DATA_PATH
# on the host. Point it at a large external drive if needed.

# Root folder for Postgres, Redis, and default PMTiles bind mount.
# Layout:
#   $WAYFINDER_DATA_PATH/postgres/
#   $WAYFINDER_DATA_PATH/pmtiles/
#   $WAYFINDER_DATA_PATH/redis/
WAYFINDER_DATA_PATH=./storage/data

# Optional: mount PMTiles from a different host folder.
# WAYFINDER_PMTILES_HOST_PATH=/mnt/maptiles

# Host ports exposed on this machine
WAYFINDER_DB_PORT=18090
WAYFINDER_REDIS_PORT=18091
SERVERPOD_API_SERVER_PORT=18080
SERVERPOD_WEB_SERVER_PORT=18082
SERVERPOD_INSIGHTS_SERVER_PORT=18081

# Public hostnames returned to clients (use this machine's LAN IP or DNS when
# browsers on other machines will connect — must match WAYFINDER_*_URL on the
# client container).
SERVERPOD_API_SERVER_PUBLIC_HOST=192.168.1.10
SERVERPOD_API_SERVER_PUBLIC_PORT=18080
SERVERPOD_WEB_SERVER_PUBLIC_HOST=192.168.1.10
SERVERPOD_WEB_SERVER_PUBLIC_PORT=18082

# Database passwords (must match config/passwords.yaml if you change them)
# POSTGRES_PASSWORD=hoMP8M6XziidHgRLWdYWIChJN64gcPhV
# REDIS_PASSWORD=jZSPtad_20Z4JmPOazsDurPauqOk9FlM
