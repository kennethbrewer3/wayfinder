# Copy to `.env` before starting the geocoding server stack.
#
#   docker compose pull
#   docker compose up -d

POSTGRES_PASSWORD=your-strong-postgres-password

# Host folder for geocoding Postgres data (can be large — planet import is tens of GB).
WAYFINDER_GEOCODING_DATA_PATH=./storage/data

# Host ports (defaults avoid conflicting with the main Wayfinder server on 18080/18082/18090).
WAYFINDER_GEOCODING_DB_PORT=18290
SERVERPOD_API_SERVER_PORT=18180
SERVERPOD_WEB_SERVER_PORT=18182

# Public hostnames for browsers/clients (not localhost when remote machines connect).
SERVERPOD_API_SERVER_PUBLIC_HOST=192.168.1.10
SERVERPOD_API_SERVER_PUBLIC_PORT=18180
SERVERPOD_WEB_SERVER_PUBLIC_HOST=192.168.1.10
SERVERPOD_WEB_SERVER_PUBLIC_PORT=18182

# Override to pin a specific release (default: latest from main).
# WAYFINDER_GEOCODING_SERVER_IMAGE=ghcr.io/kennethbrewer3/wayfinder-geocoding-server:latest
