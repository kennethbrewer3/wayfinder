# Copy to `.env` in this directory before starting the server stack.
#
#   docker compose up -d --build
#
# All persistent data (Postgres, Redis, PMTiles) is stored under WAYFINDER_DATA_PATH
# on the host. Point it at a large external drive if needed.

# Root folder for Postgres, Redis, and default PMTiles bind mount.
# Layout:
#   $WAYFINDER_DATA_PATH/postgres/
#   $WAYFINDER_DATA_PATH/pmtiles/
#   $WAYFINDER_DATA_PATH/redis/
WAYFINDER_DATA_PATH=./storage/data

# Optional: mount PMTiles from a different host folder (shared with another app).
# WAYFINDER_PMTILES_HOST_PATH=/mnt/shared/maps/pmtiles
# WAYFINDER_PMTILES_MOUNT_OPTIONS=:ro

# Host ports exposed on this machine
WAYFINDER_DB_PORT=18090
WAYFINDER_REDIS_PORT=18091
SERVERPOD_API_SERVER_PORT=18080
SERVERPOD_WEB_SERVER_PORT=18082
SERVERPOD_INSIGHTS_SERVER_PORT=18081

# Public hostnames returned to clients (use this machine's LAN IP or DNS when
# browsers on other machines will connect — must match WAYFINDER_*_URL on the
# client container).
SERVERPOD_API_SERVER_PUBLIC_HOST=192.168.1.10
SERVERPOD_API_SERVER_PUBLIC_PORT=18080
SERVERPOD_WEB_SERVER_PUBLIC_HOST=192.168.1.10
SERVERPOD_WEB_SERVER_PUBLIC_PORT=18082

# Required — choose strong passwords and keep .env out of version control.
POSTGRES_PASSWORD=change-me-postgres-password
REDIS_PASSWORD=change-me-redis-password

# Auth secrets for Serverpod (required in Docker — the GHCR image has no passwords.yaml).
# For local `dart bin/main.dart`, copy config/passwords.yaml.example to passwords.yaml instead.
# Generate each value: openssl rand -base64 32
SERVERPOD_PASSWORD_serviceSecret=change-me-service-secret
SERVERPOD_PASSWORD_emailSecretHashPepper=change-me-email-pepper
SERVERPOD_PASSWORD_jwtHmacSha512PrivateKey=change-me-jwt-signing-key
SERVERPOD_PASSWORD_jwtRefreshTokenHashPepper=change-me-jwt-refresh-pepper

# Used only by: docker compose --profile test up -d
POSTGRES_TEST_PASSWORD=change-me-test-postgres-password
REDIS_TEST_PASSWORD=change-me-test-redis-password
