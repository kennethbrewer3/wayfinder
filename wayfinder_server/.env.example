# Copy to `.env` in this directory and adjust for your machine.
#
# Start the full stack (Postgres, Redis, Wayfinder server):
#   docker compose up -d --build
#
# Start the Flutter web client as a separate container:
#   docker compose --profile client up -d --build
#
# Start server and client together:
#   docker compose --profile client up -d --build postgres redis server client
#
# IMPORTANT: set WAYFINDER_PMTILES_HOST_PATH to your local map tiles folder.
# Without this, Docker uses ./storage/pmtiles (empty except uploads).

# Host folder containing .pmtiles map archives (mounted at /data/pmtiles).
# Supports files in subfolders. Pre-existing files are registered automatically.
WAYFINDER_PMTILES_HOST_PATH=/Volumes/maptiles

# Host ports (optional — defaults match development.yaml)
WAYFINDER_DB_PORT=18090
SERVERPOD_API_SERVER_PORT=18080
SERVERPOD_WEB_SERVER_PORT=18082
SERVERPOD_INSIGHTS_SERVER_PORT=18081

# Flutter web client (docker compose --profile client)
WAYFINDER_CLIENT_PORT=8080
# URLs must be reachable from the user's browser, not from inside Docker.
# When the client runs on another machine, point these at the server's host/IP.
WAYFINDER_API_URL=http://localhost:18080
WAYFINDER_WEB_URL=http://localhost:18082

# Public hostnames returned by the server (use your LAN IP or DNS name when
# accessing Wayfinder from other machines).
# SERVERPOD_API_SERVER_PUBLIC_HOST=192.168.1.10
# SERVERPOD_WEB_SERVER_PUBLIC_HOST=192.168.1.10
