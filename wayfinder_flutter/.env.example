# Copy to `.env` in this directory before starting the client container.
#
# These URLs must be reachable from the user's **browser**, not from inside
# Docker. When the client runs on a different machine than the server, use the
# server's LAN IP or DNS name.
#
# Example: server at 192.168.1.10
#   WAYFINDER_API_URL=http://192.168.1.10:18080
#   WAYFINDER_WEB_URL=http://192.168.1.10:18082

WAYFINDER_CLIENT_PORT=8080
WAYFINDER_API_URL=http://192.168.1.10:18080
WAYFINDER_WEB_URL=http://192.168.1.10:18082
# Optional — separate geocoding server (port 18182 by convention).
WAYFINDER_GEOCODING_WEB_URL=http://192.168.1.11:18182
