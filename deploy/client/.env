# Copy to `.env` in this directory before starting the client.
#
# URLs must be reachable from the user's browser (server LAN IP or DNS).
#
#   docker compose pull
#   docker compose up -d

WAYFINDER_CLIENT_PORT=8080
WAYFINDER_API_URL=http://192.168.1.10:18080
WAYFINDER_WEB_URL=http://192.168.1.10:18082

# Override to pin a specific release (default: latest from main).
# WAYFINDER_CLIENT_IMAGE=ghcr.io/kennethbrewer3/wayfinder-client:latest
